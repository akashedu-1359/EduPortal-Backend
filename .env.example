# Database
CONNECTIONSTRINGS__DEFAULTCONNECTION=Host=localhost;Port=5432;Database=eduportal;Username=postgres;Password=yourpassword

# JWT
JWTSETTINGS__SECRET=your-super-secret-key-minimum-32-characters

# Redis
REDIS__CONNECTIONSTRING=localhost:6379

# Cloudflare R2 Storage
STORAGE__ACCOUNTID=your-cloudflare-account-id
STORAGE__BUCKETNAME=eduportal-files
STORAGE__ACCESSKEYID=your-r2-access-key-id
STORAGE__SECRETACCESSKEY=your-r2-secret-access-key

# Resend Email
EMAIL__RESENDAPIKEY=re_your_resend_api_key
EMAIL__FROMADDRESS=noreply@yourdomain.com

# Google OAuth
GOOGLE__CLIENTID=your-google-client-id
GOOGLE__CLIENTSECRET=your-google-client-secret

# Stripe
STRIPE__SECRETKEY=sk_test_...
STRIPE__WEBHOOKSECRET=whsec_...

# Razorpay
RAZORPAY__KEYID=rzp_test_...
RAZORPAY__KEYSECRET=your-razorpay-secret
